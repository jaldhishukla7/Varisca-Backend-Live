{
  "name": "varisca-backend",
  "version": "1.0.0",
  "description": "Varisca E-Commerce Backend API",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:fresh": "npx --yes kill-port 3001 && tsx watch src/index.ts",
    "build": "tsc",
    "start": "npx --yes kill-port 3001 && node dist/index.js",
    "start:only": "node dist/index.js",
    "migrate": "tsx src/migrate.ts",
    "migrate:supabase": "cross-env DB_SOURCE=url tsx src/migrate.ts",
    "seed": "tsx src/seed.ts",
    "seed:supabase": "cross-env DB_SOURCE=url tsx src/seed.ts",
    "setup": "tsx src/migrate.ts && tsx src/seed.ts",
    "setup:supabase": "cross-env DB_SOURCE=url tsx src/migrate.ts && cross-env DB_SOURCE=url tsx src/seed.ts"
  },
  "dependencies": {
    "@types/express-rate-limit": "^5.1.3",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "pg": "^8.13.0",
    "razorpay": "^2.9.6",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.6",
    "@types/winston": "^2.4.4",
    "cross-env": "^10.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
